  "item": [
    {
      "name": "create board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"board created success\",()=>{\r",
              "pm.expect(pm.response.json()).to.have.property(\"id\")\r",
              "pm.expect(pm.response.json()).to.have.property(\"name\")\r",
              "})\r",
              "pm.test(\"board name is correct\",()=>{\r",
              "    pm.collectionVariables.set(\"name\",\"ahmed\")\r",
              "    const name=pm.collectionVariables.get(\"name\")\r",
              "    pm.expect(pm.response.json().name).to.equal(name)})\r",
              "    if (pm.response.id){pm.collectionVariables.set(\"boardId\",pm.response.json().id)}\r",
              "    \r",
              "    else {\r",
              "        throw new Error(\"err no response\")\r",
              "    }"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
