    {
      "name": "Create a new List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.collectionVariables.set(\"listName\",\"mylist\")\r",
              "const listname=pm.collectionVariables.get(\"listName\")\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response is accurate\", function () {\r",
              "pm.expect(pm.response.json()).to.have.property(\"id\")\r",
              "pm.expect(pm.response.json()).to.have.property(\"name\")\r",
              "})\r",
              "pm.test(\"list name is correct\",()=>{\r",
              "   \r",
              "    pm.expect(pm.response.json().name).to.equal(listname)})\r",
              "    if (pm.response.id){pm.collectionVariables.set(\"listId\",String(pm.response.json().id))}\r",
              "    \r",
              "    else {\r",
              "        throw new Error(\"err no response\")\r",
              "    }"
            ],
